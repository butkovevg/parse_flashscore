// Читаем файл с логами
local.file "log_file" {
  filename = "/app/logs/log_detailed_FLASHSCORE.log"
}

// Отправляем напрямую в Loki
loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

// Источник логов → Loki
loki.source.file "fastapi_logs" {
  targets = [{
    __path__ = "/app/logs/log_detailed_FLASHSCORE.log",
    labels = {
      job = "fastapi",
      instance = "host"
    }
  }]
  forward_to = [loki.write.default.receiver]
}